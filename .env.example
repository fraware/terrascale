# Copy to `.env` in the repository root for docker compose (optional; compose uses defaults).

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=usersdb
POSTGRES_USER=user
POSTGRES_PASSWORD=password

REDIS_HOST=redis
REDIS_PORT=6379

CACHE_TTL_SECONDS=3600
DEBUG=false
LOG_LEVEL=INFO

# Optional OpenTelemetry OTLP HTTP traces endpoint (e.g. http://jaeger:4318/v1/traces)
# OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=user-service
